<!DOCTYPE html>
<html lang="fr">
  <head>
    <script>
      (function() {
        var stored = localStorage.getItem("theme");
        var theme = stored || "dark";
        document.documentElement.setAttribute("data-theme", theme);
      })();
    </script>
    <meta charset="UTF-8"/>
    <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
    <title>{{ name }} — {{ title }} | Talvin Ackbaraly</title>
    <meta name="description" content="{{ tagline }}"/>
    <link rel="canonical" href="{{ site.baseUrl }}/projects/{{ id }}/"/>
    <meta property="og:type" content="article"/>
    <meta property="og:url" content="{{ site.baseUrl }}/projects/{{ id }}/"/>
    <meta property="og:title" content="{{ name }} — {{ title }}"/>
    <meta property="og:description" content="{{ tagline }}"/>
    {% if thumbnail %}
      <meta property="og:image" content="{{ site.baseUrl }}{{ thumbnail }}"/>
    {% endif %}
    <meta name="twitter:card" content="summary_large_image"/>
    <meta name="twitter:title" content="{{ name }} — {{ title }}"/>
    <meta
    name="twitter:description" content="{{ tagline }}"/> <!-- Favicon -->
    <link
    rel="icon" href="/assets/favicon.svg" type="image/svg+xml"/> <!-- Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com"/>
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin/>
    <link
    href="https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@400;500;600;700&family=Inter:wght@400;500&display=swap"
      rel="stylesheet"/> <!-- Styles -->
    <link rel="stylesheet" href="/css/style.css"/>
    <!-- KaTeX Math Rendering -->
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/katex@0.16.9/dist/katex.min.css" crossorigin="anonymous"/>
    <script defer src="https://cdn.jsdelivr.net/npm/katex@0.16.9/dist/katex.min.js" crossorigin="anonymous"></script>
    <script defer src="https://cdn.jsdelivr.net/npm/katex@0.16.9/dist/contrib/auto-render.min.js" crossorigin="anonymous" onload="renderMathInElement(document.body, { delimiters: [{left: '$$', right: '$$', display: true}, {left: '$', right: '$', display: false}] });"></script>
  </head>
  <body>
    <!-- ─── Navigation ─── -->
    <nav class="nav" id="nav" aria-label="Navigation principale">
      <div class="nav__inner container">
        <a href="/" class="nav__logo" aria-label="Retour à l'accueil">TA</a>
        <ul class="nav__links" role="list">
          <li>
            <a href="/#about">À propos</a>
          </li>
          <li>
            <a href="/#experience">Expériences</a>
          </li>
          <li>
            <a href="/#projects">Projets</a>
          </li>
          <li>
            <a href="/#skills">Compétences</a>
          </li>
          <li>
            <a href="/#contact">Contact</a>
          </li>
        </ul>
        <div class="nav__controls">
          <button class="nav__theme-toggle" id="theme-toggle" aria-label="Basculer le thème clair/sombre" type="button">
            <svg
              class="icon-sun"
              xmlns="http://www.w3.org/2000/svg"
              width="18"
              height="18"
              viewbox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="2"
              stroke-linecap="round"
              stroke-linejoin="round"><circle cx="12" cy="12" r="5"/><line x1="12" y1="1" x2="12" y2="3"/><line x1="12" y1="21" x2="12" y2="23"/><line x1="4.22" y1="4.22" x2="5.64" y2="5.64"/><line x1="18.36" y1="18.36" x2="19.78" y2="19.78"/><line x1="1" y1="12" x2="3" y2="12"/><line x1="21" y1="12" x2="23" y2="12"/><line x1="4.22" y1="19.78" x2="5.64" y2="18.36"/><line x1="18.36" y1="5.64" x2="19.78" y2="4.22"/>
            </svg>
            <svg
              class="icon-moon"
              xmlns="http://www.w3.org/2000/svg"
              width="18"
              height="18"
              viewbox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="2"
              stroke-linecap="round"
              stroke-linejoin="round"><path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"/>
            </svg>
          </button>
        </div>
        <button class="nav__burger" id="nav-burger" aria-label="Ouvrir le menu" aria-expanded="false" type="button">
          <span></span>
          <span></span>
          <span></span>
        </button>
      </div>
    </nav>
    <!-- ─── Mobile Menu Overlay ─── -->
    <div class="mobile-menu" id="mobile-menu" aria-hidden="true">
      <ul class="mobile-menu__links" role="list">
        <li>
          <a href="/#about">À propos</a>
        </li>
        <li>
          <a href="/#experience">Expériences</a>
        </li>
        <li>
          <a href="/#projects">Projets</a>
        </li>
        <li>
          <a href="/#skills">Compétences</a>
        </li>
        <li>
          <a href="/#contact">Contact</a>
        </li>
      </ul>
    </div>
    <main
      class="project-page">
      <!-- ─── Back Link ─── -->
      <div class="project-page__back container">
        <a href="/#projects" class="project-back-link">
          <svg
            xmlns="http://www.w3.org/2000/svg"
            width="16"
            height="16"
            viewbox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2"
            stroke-linecap="round"
            stroke-linejoin="round"><polyline points="15 18 9 12 15 6"/>
          </svg>
          Retour aux projets
        </a>
      </div>
      <!-- ─── Hero Project ─── -->
      <header class="project-hero">
        <div class="container project-hero__inner">
          <div class="project-hero__meta">
            <span class="project-badge">{{ name }}</span>
            {% if period %}
              <span class="project-hero__period">{{ period }}</span>
            {% endif %}
            {% if team %}
              <span class="project-hero__team">
                <svg
                  xmlns="http://www.w3.org/2000/svg"
                  width="14"
                  height="14"
                  viewbox="0 0 24 24"
                  fill="none"
                  stroke="currentColor"
                  stroke-width="2"
                  stroke-linecap="round"
                  stroke-linejoin="round"><path d="M16 21v-2a4 4 0 0 0-4-4H6a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M22 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/>
                </svg>
                {{ team }} pers.
              </span>
            {% endif %}
          </div>
          <h1 class="project-hero__title">{{ title }}</h1>
          <p class="project-hero__tagline">{{ tagline }}</p>
          <!-- Stack tags -->
          {% if stack %}
            <div class="project-hero__stack">
              {% for s in stack %}
                <span class="tag">{{ s }}</span>
              {% endfor %}
            </div>
          {% endif %}
          <!-- Action links -->
          {% if github or demo or report %}
            <div class="project-hero__links">
              {% if github %}
                <a href="{{ github }}" target="_blank" rel="noopener noreferrer" class="btn btn--outline">
                  <svg
                    xmlns="http://www.w3.org/2000/svg"
                    width="16"
                    height="16"
                    viewbox="0 0 24 24"
                    fill="none"
                    stroke="currentColor"
                    stroke-width="2"
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    class="btn__icon"><path d="M15 22v-4a4.8 4.8 0 0 0-1-3.5c3 0 6-2 6-5.5.08-1.25-.27-2.48-1-3.5.28-1.15.28-2.35 0-3.5 0 0-1 0-3
                      1.5-2.64-.5-5.36-.5-8 0C6 2 5 2 5 2c-.3 1.15-.3 2.35 0 3.5A5.403 5.403 0 0 0 4 9c0 3.5 3 5.5 6 5.5-.39.49-.68 1.05-.85
                      1.65-.17.6-.22 1.23-.15 1.85v4"/><path d="M9 18c-4.51 2-5-2-7-2"/>
                  </svg>
                  GitHub
                </a>
              {% endif %}
              {% if demo %}
                <a href="{{ demo }}" target="_blank" rel="noopener noreferrer" class="btn btn--primary">
                  <svg
                    xmlns="http://www.w3.org/2000/svg"
                    width="16"
                    height="16"
                    viewbox="0 0 24 24"
                    fill="none"
                    stroke="currentColor"
                    stroke-width="2"
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    class="btn__icon"><path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6"/><polyline points="15 3 21 3 21 9"/><line x1="10" x2="21" y1="14" y2="3"/>
                  </svg>
                  Démo
                </a>
              {% endif %}
              {% if report %}
                <a href="{{ report }}" target="_blank" rel="noopener noreferrer" class="btn btn--outline">
                  <svg
                    xmlns="http://www.w3.org/2000/svg"
                    width="16"
                    height="16"
                    viewbox="0 0 24 24"
                    fill="none"
                    stroke="currentColor"
                    stroke-width="2"
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    class="btn__icon"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/><polyline points="7 10 12 15 17 10"/><line x1="12" x2="12" y1="15" y2="3"/>
                  </svg>
                  Rapport PDF
                </a>
              {% endif %}
            </div>
          {% endif %}
        </div>
      </header>
      <!-- ─── Thumbnail ─── -->
      {% set thumb = thumbnail if thumbnail else "/assets/projects/placeholder.png" %}
      <div class="project-thumbnail container">
        <img src="{{ thumb }}" alt="Aperçu du projet {{ name }}" class="project-thumbnail__img" loading="lazy" onerror="this.onerror=null;this.src='/assets/projects/placeholder.png';"/>
      </div>
      <!-- ─── Content (Markdown rendered) ─── -->
      <article class="project-content container">
        {{ content | safe }}
      </article>
    </main>
    <!-- ─── Footer ─── -->
    <footer class="footer">
      <div class="container footer__inner">
        <div class="footer__brand">
          <span class="footer__logo">TA</span>
          <span class="footer__name">Talvin Ackbaraly</span>
        </div>
        <ul class="footer__links" role="list">
          <li>
            <a href="https://www.linkedin.com/in/talvin-ackbaraly/" target="_blank" rel="noopener noreferrer">LinkedIn</a>
          </li>
          <li>
            <a href="https://github.com/talvinckb" target="_blank" rel="noopener noreferrer">GitHub</a>
          </li>
        </ul>
        <p class="footer__copy">&copy;
          <span>2026</span>
          Talvin Ackbaraly</p>
      </div>
    </footer>
    <!-- Scripts -->
    <script type="module" src="/js/project.js"></script>
  </body>
</html>